{
  "rules": {
    "no-unused-vars": "warn",
    "no-accumulating-spread": "error",
    "no-await-in-loop": "off",
    "explicit-length-check": "off",
    "no-array-callback-reference": "off",
    "max-lines": ["off", { "max": 500 }],
    "max-lines-per-function": ["off", { "max": 150 }],
    "unicorn/consistent-function-scoping": "off",
    "no-warning-comments": "off",
    "no-array-sort": "off",
    "strict-boolean-expressions": "off",
    "no-confusing-void-expression": "off",
    "no-misused-promises": "off",
    "no-floating-promises": "off",
    "no-loop-func": "off",
    "eslint/eqeqeq": "off",
    "complexity": ["warn", { "max": 40 }],
    "max-depth": ["warn", { "max": 4 }],
    "max-nested-callbacks": ["warn", { "max": 4 }],
    "no-map-spread": "off",
    "no-shadow": "off",
    "typescript/consistent-type-imports": "error",
    "no-new": "off"
  },
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error",
    "pedantic": "error"
  },
  "ignorePatterns": ["dist", "node_modules", "*.config.*"],
  "overrides": [
    {
      "files": ["src/**/*.ts"],
      "jsPlugins": [
        { "name": "omnarr", "specifier": "./oxlint/omnarr-plugin.js" }
      ],
      "rules": {
        "omnarr/no-raw-throw": "error"
      }
    },
    {
      "files": [
        "src/shared/errors.ts",
        "src/player/**",
        "src/commands/**",
        "src/audio/**",
        "src/core/exporter.ts",
        "src/core/subtitle-matcher.ts",
        "src/jobs/**",
        "src/integrations/indexers/**"
      ],
      "rules": {
        "omnarr/no-raw-throw": "off"
      }
    },
    {
      "files": ["tests/web/**"],
      "jsPlugins": [
        { "name": "omnarr", "specifier": "./oxlint/omnarr-plugin.js" }
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@testing-library/react",
                "message": "Import from tests/web/testing-library.ts instead."
              },
              {
                "name": "@testing-library/user-event",
                "message": "Import from tests/web/testing-library.ts instead."
              }
            ]
          }
        ],
        "omnarr/no-dom-queries": "error"
      }
    },
    {
      "files": ["tests/web/testing-library.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["tests/web/dom.ts"],
      "rules": {
        "omnarr/no-dom-queries": "off"
      }
    }
  ]
}
