{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "indexers": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "api_key": {
                "type": "string"
              },
              "rss_key": {
                "type": "string"
              },
              "type": {
                "const": "beyond-hd"
              }
            },
            "required": [
              "api_key",
              "rss_key",
              "type"
            ]
          },
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "yts"
              }
            },
            "required": [
              "type"
            ]
          }
        ]
      },
      "default": []
    },
    "download_client": {
      "type": "object",
      "properties": {
        "password": {
          "type": "string"
        },
        "type": {
          "const": "qbittorrent"
        },
        "url": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "default": "omnarr"
        }
      },
      "required": [
        "password",
        "type",
        "url",
        "username"
      ]
    },
    "root_folders": {
      "type": "object",
      "properties": {
        "movie": {
          "type": "string"
        },
        "tv": {
          "type": "string"
        }
      }
    }
  }
}
