{
  "name": "omnarr",
  "version": "0.2",
  "description": "CLI media manager",
  "bin": "./dist/omnarr",
  "type": "module",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build.ts",
    "check": "bun run scripts/check.ts",
    "generate-schema": "bun run scripts/generate-schema.ts",
    "dev:web": "concurrently 'tsr watch' 'bun --watch src/web/server.ts'",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@bunli/core": "^0.9.0",
    "@bunli/test": "^0.6.0",
    "@lobomfz/bunmq": "link:@lobomfz/bunmq",
    "@lobomfz/db": "link:@lobomfz/db",
    "@lobomfz/ffmpeg": "link:@lobomfz/ffmpeg",
    "@lobomfz/ghostapi": "^0.3.4",
    "@tanstack/router-cli": "^1.166.25",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "bun-plugin-tailwind": "^0.1.2",
    "concurrently": "^9.2.1",
    "dayjs": "^1.11.20",
    "jscpd": "^4.0.8",
    "knip": "^6.2.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "redaxios": "^0.5.1",
    "tailwindcss": "^4.2.2"
  },
  "overrides": {
    "@opentui/core": "0.1.92"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@orpc/client": "^1.13.13",
    "@orpc/experimental-publisher": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/tanstack-query": "^1.13.13",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "fuzzball": "^2.2.3",
    "lucide-react": "^1.7.0",
    "onnxruntime-node": "^1.24.3",
    "p-queue": "^9.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "trustedDependencies": [
    "onnxruntime-node"
  ]
}
