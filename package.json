{
  "name": "omnarr",
  "version": "0.1.4",
  "description": "CLI media manager",
  "bin": "./dist/omnarr",
  "type": "module",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "os": [
    "linux"
  ],
  "cpu": [
    "x64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "check": "bun run scripts/check.ts",
    "generate-schema": "bun run scripts/generate-schema.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@bunli/core": "^0.9.0",
    "@bunli/test": "^0.6.0",
    "@lobomfz/db": "link:@lobomfz/db",
    "@lobomfz/ffmpeg": "link:@lobomfz/ffmpeg",
    "@lobomfz/ghostapi": "^0.3.4",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260331.1",
    "arktype": "^2.2.0",
    "dayjs": "^1.11.20",
    "jscpd": "^4.0.8",
    "knip": "^6.1.1",
    "kysely": "^0.28.15",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "redaxios": "^0.5.1"
  },
  "overrides": {
    "@opentui/core": "0.1.92"
  }
