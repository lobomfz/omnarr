{
  "name": "omnarr",
  "version": "0.1.4",
  "description": "CLI media manager",
  "bin": "./dist/omnarr",
  "type": "module",
  "files": [
    "dist",
    "config.schema.json"
  ],
  "os": [
    "linux"
  ],
  "cpu": [
    "x64"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run build.ts",
    "check": "bun run scripts/check.ts",
    "generate-schema": "bun run scripts/generate-schema.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@bunli/core": "^0.8.2",
    "@bunli/test": "^0.5.2",
    "@lobomfz/db": "^0.3.2",
    "@lobomfz/ffmpeg": "^0.1.0",
    "@lobomfz/ghostapi": "^0.3.1",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260325.1",
    "arktype": "^2.2.0",
    "dayjs": "^1.11.20",
    "jscpd": "^4.0.8",
    "knip": "^6.0.5",
    "kysely": "^0.28.14",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "redaxios": "^0.5.1"
  }
